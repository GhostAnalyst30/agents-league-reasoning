# Azure Foundry project (models)
AZURE_AI_PROJECT_ENDPOINT=https://<resource>.services.ai.azure.com/api/projects/<project>
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/openai/v1
AZURE_AI_API_KEY=<foundry-api-key>
AZURE_AI_MODEL_DEPLOYMENT=gpt-oss-120b
AZURE_AI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Azure AI Search (Foundry IQ)
AZURE_SEARCH_ENDPOINT=https://<search-service>.search.windows.net
AZURE_SEARCH_API_KEY=<search-admin-key>
FOUNDRY_IQ_KB_NAME=certpilot-kb
